<div class='modal js-modal' tabindex='-1' id='modal-order'>
    <div class='modal-dialog modal-dialog-centered'>
        <div class='modal-content'>
            <div class='modal-header'>
                <p class='modal-title h2'>Узнать цену</p>
                <button type='button' class='btn-close' data-bs-dismiss='modal' aria-label='Close'></button>
            </div>
            <div class='modal-body'>
                <form>
                    <div class='my-4'>
                        <label class='visually-hidden' for='f-firstname'>Имя</label>
                        <input type='text' class='form-control' placeholder='Имя' aria-label='Имя' id='f-firstname' />
                    </div>

                    <div class='mb-4'>
                        <label class='visually-hidden' for='f-phone'>Телефон</label>
                        <input type='text' class='form-control' placeholder='+7 (___) ___-__-__' aria-label='Телефон' id='f-phone' />
                    </div>

                    <div class='mb-4'>
                        <label class='visually-hidden' for='f-email'>Email</label>
                        <input type='text' class='form-control is-invalid' placeholder='Email' aria-label='E-mail' id='f-email' />
                    </div>

                    <div class='mb-4'>
                        <label class='visually-hidden' for='f-company'>Название компании</label>
                        <input type='text' class='form-control' placeholder='Название компании' aria-label='Название компании' id='f-company' />
                    </div>
                    <button type='submit' class='btn btn-primary w-100'>Отправить</button>
                </form>
            </div>
        </div>
    </div>
</div>
<div class='modal js-modal' tabindex='-1' id='modal-callback'>
    <div class='modal-dialog modal-dialog-centered'>
        <div class='modal-content'>
            <div class='modal-header'>
                <p class='modal-title h2'>Заказать звонок</p>
                <button type='button' class='btn-close' data-bs-dismiss='modal' aria-label='Close'></button>
            </div>
            <div class='modal-body'>
                <form>
                    <div class='my-4'>
                        <label class='visually-hidden' for='c-firstname'>Имя</label>
                        <input type='text' class='form-control' placeholder='Имя' aria-label='Имя' id='c-firstname' />
                    </div>

                    <div class='mb-4'>
                        <label class='visually-hidden' for='c-phone'>Телефон</label>
                        <input type='text' class='form-control' placeholder='+7 (___) ___-__-__' aria-label='Телефон' id='c-phone' />
                    </div>

                    <div class='mb-4'>
                        <label class='visually-hidden' for='c-company'>Название компании</label>
                        <input type='text' class='form-control' placeholder='Название компании' aria-label='Название компании' id='c-company' />
                    </div>
                    <button type='submit' class='btn btn-primary w-100'>Отправить</button>
                </form>
            </div>
        </div>
    </div>
</div>
<div class='modal js-modal' tabindex='-1' id='modal-success'>
    <div class='modal-dialog modal-dialog-centered'>
        <div class='modal-content'>
            <div class='modal-body text-center info-body'>
                <div class='i-check info-body__i'></div>
                <p class='my-2 info-body__title'>Заявка отправлена</p>
                <p class='mt-2 mb-4'>В ближайшее время менеджер свяжется с вами для подробной консультации.</p>
                <button type='submit' class='btn btn-primary w-100' data-bs-dismiss='modal'>Закрыть</button>
            </div>
        </div>
    </div>
</div>
<div class='modal js-modal' tabindex='-1' id='modal-error'>
    <div class='modal-dialog modal-dialog-centered'>
        <div class='modal-content'>
            <div class='modal-body text-center info-body info-body--error'>
                <div class='i-x info-body__i'></div>
                <p class='my-2 info-body__title'>Что-то пошло не так...</p>
                <p class='mt-2 mb-4'>Ошибка отправки. Попробуйте снова  или свяжитесь с нами другим способом.</p>
                <button type='submit' class='btn btn-primary w-100' data-bs-dismiss='modal'>Отправить еще раз</button>
                <div class='info-body__contacts mt-6'>
                    <div class='contact-box contact-box--iconed'>
                        <span class='i-phone contact-box__icon'></span>
                        <div class='contact-box__head'>8-800-777-07-04</div>
                        <div class='contact-box__sub'>Бесплатно по России</div>
                    </div>
                    <div class='divider'></div>
                    <div class='socials-box'>
                        <a href='#' class='i-whatsapp' target='_blank'></a>
                        <a href='#' class='i-youtube' target='_blank'></a>
                        <a href='#' class='i-telegram' target='_blank'></a>
                        <a href='#' class='i-dzen' target='_blank'></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>