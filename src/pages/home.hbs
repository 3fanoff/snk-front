{{#> layout/base-layout}}
    <!-- Каталог плитки -->
    {{> catalog-grid }}
    <!-- Сопровождение на всех этапах = Карусель -->
    {{> card-carousel-escort }}
    <!-- Собственный сервисный центр basic-text-box + icon -->
    {{> service-center }}
    <!-- Популярное оборудование = карусель с выравниванием в центре -->
    {{> card-carousel-popular addClasses="" }}
    <!-- Синяя форма = color-box форма и текст -->
    {{> color-box-form }}
    <!-- О компании = текст и basic-text-box + icon-center-->
    {{> about }}
    <!-- Карта -->
    {{> map-box }}
    <!-- Карусель логотипов -->
    {{> logos-carousel }}
{{/layout/base-layout}}